<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="120dp">

            <!-- Profile Cover -->
            <ImageView
                android:id="@+id/ivProfileCover"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_dashboard_header"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="#40000000"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- AVATAR AREA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutAvatarCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="60dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/white"
                app:strokeWidth="3dp"
                app:layout_constraintBottom_toBottomOf="@id/ivProfileCover"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivProfileCover">

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfilePic"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImage" />
                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:gravity="center"
                        android:textSize="50sp" />

                    <!-- EDIT BUTTON INSIDE IMAGE -->
                    <ImageButton
                        android:id="@+id/btnEditAvatarInside"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_item_circle"
                        android:backgroundTint="?attr/colorPrimary"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/white"
                        android:padding="8dp"
                        android:scaleType="fitCenter" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/layoutAvatarCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvProfileXP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/tvProfileName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/btnViewAchievementsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_points_badge"
                android:backgroundTint="@color/brand_rose"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvProfileXP"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievements_button"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- SETTINGS CONTAINER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_floating_card"
                android:backgroundTint="?attr/colorSurface"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/btnViewAchievementsRow">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="12dp" />

                <!-- THEME -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/app_theme_label" android:textColor="?android:attr/textColorPrimary" />
                    <Spinner android:id="@+id/spinnerTheme" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <!-- SWITCHES -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/enable_notifications" android:textColor="?android:attr/textColorPrimary" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchNotifications" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/dark_mode" android:textColor="?android:attr/textColorPrimary" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchDarkMode" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/sound_enabled" android:textColor="?android:attr/textColorPrimary" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchSound" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/vibration" android:textColor="?android:attr/textColorPrimary" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchVibration" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <!-- TONES -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/notification_sounds_label" android:textColor="?android:attr/textColorPrimary" android:textStyle="bold" android:layout_marginTop="12dp" />

                <LinearLayout android:id="@+id/btnToneStartTask" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/start_task_tone" android:textColor="?android:attr/textColorPrimary" />
                    <TextView android:id="@+id/tvToneStartTask" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/default_label" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <LinearLayout android:id="@+id/btnToneEndTask" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/end_task_tone" android:textColor="?android:attr/textColorPrimary" />
                    <TextView android:id="@+id/tvToneEndTask" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/default_label" android:textColor="?attr/colorPrimary" />
                </LinearLayout>
                <LinearLayout android:id="@+id/btnToneAchievement" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/new_achievement_tone" android:textColor="?android:attr/textColorPrimary" />
                    <TextView android:id="@+id/tvToneAchievement" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/default_label" android:textColor="?attr/colorPrimary" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" android:layout_marginTop="8dp" />

                <!-- LANG -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/language" android:textColor="?android:attr/textColorPrimary" />
                    <Spinner android:id="@+id/spinnerLanguage" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <!-- ACTIONS -->
                <TextView android:id="@+id/btnHelpCenterRow" android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:text="@string/how_to_use_hibts" android:textColor="?android:attr/textColorPrimary" android:clickable="true" android:focusable="true" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <TextView android:id="@+id/btnTermsRow" android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:text="@string/terms_of_use" android:textColor="?android:attr/textColorPrimary" android:clickable="true" android:focusable="true" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <TextView android:id="@+id/btnBackupRow" android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:text="Backup" android:textColor="?android:attr/textColorPrimary" android:clickable="true" android:focusable="true" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <TextView android:id="@+id/btnRestoreRow" android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:text="Restore" android:textColor="?android:attr/textColorPrimary" android:clickable="true" android:focusable="true" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <TextView android:id="@+id/btnLogoutRow" android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:text="@string/logout" android:textColor="@color/accent_pink" android:textStyle="bold" android:clickable="true" android:focusable="true" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_light" />

                <TextView android:id="@+id/btnResetAppRow" android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:text="@string/reset_app_data" android:textColor="@color/accent_pink" android:clickable="true" android:focusable="true" />

                <TextView android:id="@+id/tvVersionName" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:gravity="center" android:textColor="@color/text_gray" android:textSize="12sp" />

                <TextView android:id="@+id/tvBirthdateCountdown" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textColor="?attr/colorPrimary" android:layout_marginTop="8dp" />

                <!-- HIDDEN IDS -->
                <View android:id="@+id/btnEditCover" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <View android:id="@+id/btnToneYearGoal" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <View android:id="@+id/btnToneHabit" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <View android:id="@+id/btnToneBirthday" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tvToneYearGoal" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tvToneHabit" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tvToneBirthday" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>