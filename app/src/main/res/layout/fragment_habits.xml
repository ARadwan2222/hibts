<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- Many small faded emojis background -->
    <TextView
        android:id="@+id/tvBgDecorations"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.08"
        android:gravity="center"
        android:padding="20dp"
        android:lineSpacingExtra="28dp"
        android:text=""
        android:textSize="14sp" />

    <!-- FIXED HEADER AREA -->
    <View
        android:id="@+id/viewHeaderBg"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_dashboard_header"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivProfilePicTop"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_profile_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/CircleImage" />

    <TextView
        android:id="@+id/tvUserNameMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="User"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivProfilePicTop"
        app:layout_constraintStart_toEndOf="@id/ivProfilePicTop"
        app:layout_constraintTop_toTopOf="@id/ivProfilePicTop" />

    <ImageButton
        android:id="@+id/btnNotifications"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_notification"
        app:layout_constraintBottom_toBottomOf="@id/ivProfilePicTop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivProfilePicTop"
        app:tint="@color/white" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFocus"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="?attr/colorPrimary"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/ivProfilePicTop">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">
            <TextView android:id="@+id/tvFocusInspiration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Focus" android:textColor="@color/white" android:textStyle="bold" />
            <TextView android:id="@+id/tvFocusTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="..." android:textColor="#FFEB3B" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvFocusTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00:00" android:textColor="#CCFFFFFF" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- SCROLLABLE LIST AREA -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardFocus">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_floating_card"
            android:backgroundTint="?attr/colorSurface"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="100dp">

            <TextView android:id="@+id/tvDateHeader" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date" android:textColor="@color/text_gray" android:layout_marginStart="8dp" />

            <!-- Sections with Restore (+) buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:id="@+id/layoutTasksTitle" android:layout_marginTop="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/today_tasks_label" android:textColor="?attr/colorPrimary" android:textStyle="bold" android:textSize="16sp" />
                <ImageButton android:id="@+id/btnAddTaskPlus" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_plus" app:tint="?attr/colorPrimary" />
                <ImageView android:id="@+id/ivTodayTasksArrow" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_down" app:tint="?attr/colorPrimary" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerCurrentTasks" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:id="@+id/layoutHabitsTitle" android:layout_marginTop="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/daily_habits_label" android:textColor="?attr/colorPrimary" android:textStyle="bold" android:textSize="16sp" />
                <ImageButton android:id="@+id/btnAddHabitPlus" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_plus" app:tint="?attr/colorPrimary" />
                <ImageView android:id="@+id/ivDailyHabitsArrow" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_down" app:tint="?attr/colorPrimary" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerDailyHabits" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/long_term_duties_label" android:textColor="@color/text_gray" android:textStyle="bold" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginTop="8dp" android:background="@drawable/bg_habit_item" android:padding="6dp" android:id="@+id/layoutWeeklyHeader">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/weekly_habits" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddWeeklyPlus" android:layout_width="32dp" android:layout_height="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_plus" app:tint="?attr/colorPrimary" />
                <ImageView android:id="@+id/ivWeeklyHabitsArrow" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_down" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerWeeklyHabits" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:visibility="gone" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginTop="8dp" android:background="@drawable/bg_habit_item" android:padding="6dp" android:id="@+id/layoutMonthlyHeader">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/monthly_habits" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddMonthlyPlus" android:layout_width="32dp" android:layout_height="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_plus" app:tint="?attr/colorPrimary" />
                <ImageView android:id="@+id/ivMonthlyHabitsArrow" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_down" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerMonthlyHabits" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:visibility="gone" />

            <TextView android:id="@+id/tvProgress" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:gravity="center" android:textStyle="bold" />

            <!-- Hidden UI Points for Logic -->
            <TextView android:id="@+id/tvPointsCount" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <com.google.android.material.chip.ChipGroup android:id="@+id/chipGroupFilter" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone">
                <com.google.android.material.chip.Chip android:id="@+id/chipDay" android:layout_width="0dp" android:layout_height="0dp" />
                <com.google.android.material.chip.Chip android:id="@+id/chipWeek" android:layout_width="0dp" android:layout_height="0dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Placeholder for old ID logic compatibility -->
            <LinearLayout android:id="@+id/layoutTodayTasksHeader" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <LinearLayout android:id="@+id/layoutDailyHabitsHeader" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <LinearLayout android:id="@+id/layoutWeeklyHabitsHeader" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <LinearLayout android:id="@+id/layoutMonthlyHabitsHeader" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tvTodayTasksTitle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/tvDailyHabitsTitle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>