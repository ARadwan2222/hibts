<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إضافة هدف سنوي"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <EditText
            android:id="@+id/etGoalTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="عنوان الهدف"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_input_field"
            android:padding="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="السنة المستهدفة"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textColor="#666666" />
        <Button
            android:id="@+id/btnSelectYear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="السنة: 2026"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="موعد الإنجاز المتوقع (اختياري)"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textColor="#666666" />
        <Button
            android:id="@+id/btnSelectTargetDate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="اختر الموعد"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_calendar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="خطوات التنفيذ (اختياري)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:textColor="#333333" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">
            <EditText
                android:id="@+id/etNewStep"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="أضف خطوة..."
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddStep"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:text="+"
                app:cornerRadius="25dp"
                android:padding="0dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStepsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#555555" />

        <Button
            android:id="@+id/btnSaveGoal"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="حفظ الهدف"
            android:layout_marginTop="48dp"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>